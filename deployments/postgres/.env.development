# Local development credentials (safe for local-only usage).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=broker

# Dedicated app credentials used by init.sql.
APP_DB_USER=broker_app
APP_DB_PASSWORD=broker_app_local_password

# Host-mapped port for local tools like pgAdmin and psql.
POSTGRES_PORT=5432

# Runtime postgres config selected by the container command.
PG_CONFIG_FILE=/etc/postgresql/postgresql.development.conf
